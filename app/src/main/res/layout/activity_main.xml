<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#121212">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="6dp">

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Form Identitas Mahasiswa"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:background="#5C6BC0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nama Lengkap"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etNama"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Masukkan nama..."
            android:textColor="#000000"
            android:textColorHint="#888888"
            android:padding="10dp"
            android:background="@drawable/edittext_bg"
            app:layout_constraintTop_toBottomOf="@id/tvNama"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvGender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jenis Kelamin"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/etNama"
            app:layout_constraintStart_toStartOf="parent"/>

        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvGender"
            app:layout_constraintStart_toStartOf="parent">

            <RadioButton
                android:id="@+id/rbLaki"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Laki-laki"
                android:textColor="#000000"
                android:buttonTint="#5C6BC0"/>

            <RadioButton
                android:id="@+id/rbPerempuan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Perempuan"
                android:textColor="#000000"
                android:buttonTint="#5C6BC0"/>
        </RadioGroup>

        <TextView
            android:id="@+id/tvHobi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hobi"
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/rgGender"
            app:layout_constraintStart_toStartOf="parent"/>

        <CheckBox
            android:id="@+id/cbMembaca"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Membaca"
            android:textColor="#000000"
            android:buttonTint="#5C6BC0"
            app:layout_constraintTop_toBottomOf="@id/tvHobi"
            app:layout_constraintStart_toStartOf="parent"/>

        <CheckBox
            android:id="@+id/cbCoding"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coding"
            android:textColor="#000000"
            android:buttonTint="#5C6BC0"
            app:layout_constraintTop_toBottomOf="@id/cbMembaca"
            app:layout_constraintStart_toStartOf="parent"/>

        <CheckBox
            android:id="@+id/cbOlahraga"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Olahraga"
            android:textColor="#000000"
            android:buttonTint="#5C6BC0"
            app:layout_constraintTop_toBottomOf="@id/cbCoding"
            app:layout_constraintStart_toStartOf="parent"/>

        <Button
            android:id="@+id/btnTampil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Tampilkan"
            android:textColor="#FFFFFF"
            android:background="#5C6BC0"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/cbOlahraga"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvHasil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Hasil akan muncul di sini..."
            android:textColor="#000000"
            android:layout_marginTop="12dp"
            android:padding="10dp"
            android:background="#E8EAF6"
            app:layout_constraintTop_toBottomOf="@id/btnTampil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</LinearLayout>